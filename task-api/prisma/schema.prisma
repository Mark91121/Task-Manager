// Prisma schema for Asikaso
// Database: Supabase (PostgreSQL)
//
// Supabase gives you two connection strings:
//   - DATABASE_URL : the pooled connection (port 6543, via PgBouncer) — used by the app at runtime
//   - DIRECT_URL   : the direct connection (port 5432) — used by Prisma Migrate
// Both are required below. See backend/.env.example for where to find them.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["drivenpx prisma generate
npm run devrAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#5b5bd6") // hex color used for the sidebar dot + task badge
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  tasks Task[]

  @@map("categories")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  completed   Boolean   @default(false)
  completedAt DateTime? // set/cleared on toggle — powers "completed today" analytics
  dueDate     DateTime?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([completed])
  @@index([createdAt])
  @@map("tasks")
}
